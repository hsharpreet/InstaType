<ResourceDictionary
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- ── Surface colours ──────────────────────────────────────────────── -->
    <Color x:Key="SurfaceColor">#F3F3F3</Color>
    <Color x:Key="SurfaceVariantColor">#EBEBEB</Color>
    <Color x:Key="OnSurfaceColor">#1A1A1A</Color>
    <Color x:Key="OnSurfaceVariantColor">#555555</Color>

    <!-- ── Accent ────────────────────────────────────────────────────────── -->
    <Color x:Key="AccentColor">#0078D4</Color>
    <Color x:Key="OnAccentColor">#FFFFFF</Color>

    <!-- ── Overlay ───────────────────────────────────────────────────────── -->
    <Color x:Key="OverlayBackgroundColor">#CCF0F0F5</Color>
    <Color x:Key="OverlayBorderColor">#33000000</Color>

    <!-- ── Icon colours ──────────────────────────────────────────────────── -->
    <Color x:Key="MicIconColor">#0066CC</Color>
    <Color x:Key="GearIconColor">#606070</Color>
    <Color x:Key="ActiveListenColor">#00AA55</Color>
    <Color x:Key="MutedColor">#CC2222</Color>

    <!-- ── Brushes (use DynamicResource in all XAML) ──────────────────── -->
    <SolidColorBrush x:Key="SurfaceBrush"          Color="{StaticResource SurfaceColor}"/>
    <SolidColorBrush x:Key="SurfaceVariantBrush"   Color="{StaticResource SurfaceVariantColor}"/>
    <SolidColorBrush x:Key="OnSurfaceBrush"        Color="{StaticResource OnSurfaceColor}"/>
    <SolidColorBrush x:Key="OnSurfaceVariantBrush" Color="{StaticResource OnSurfaceVariantColor}"/>
    <SolidColorBrush x:Key="AccentBrush"           Color="{StaticResource AccentColor}"/>
    <SolidColorBrush x:Key="OnAccentBrush"         Color="{StaticResource OnAccentColor}"/>
    <SolidColorBrush x:Key="OverlayBackgroundBrush" Color="{StaticResource OverlayBackgroundColor}"/>
    <SolidColorBrush x:Key="OverlayBorderBrush"    Color="{StaticResource OverlayBorderColor}"/>
    <SolidColorBrush x:Key="MicIconBrush"  Color="{StaticResource MicIconColor}"/>
    <SolidColorBrush x:Key="GearIconBrush" Color="{StaticResource GearIconColor}"/>
    <SolidColorBrush x:Key="ActiveListenBrush"     Color="{StaticResource ActiveListenColor}"/>
    <SolidColorBrush x:Key="MutedBrush"            Color="{StaticResource MutedColor}"/>

</ResourceDictionary>
