<Window
    x:Class="InstaType.Views.OverlayWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Title="InstaType"
    Width="340" Height="56"
    WindowStyle="None"
    AllowsTransparency="True"
    Background="Transparent"
    Topmost="True"
    ShowInTaskbar="False"
    ResizeMode="NoResize"
    ShowActivated="False"
    MouseLeftButtonDown="Window_MouseLeftButtonDown">

    <!-- Pill: CornerRadius=28 gives perfect semi-circle caps on a 56 px tall window.
         Background uses DynamicResource so theme switches update the colour immediately.
         BorderBrush is set to a SolidColorBrush in code-behind so a ColorAnimation
         can pulse it green while IsListening is true. -->
    <Border x:Name="PillBorder"
            CornerRadius="28"
            Background="{DynamicResource OverlayBackgroundBrush}"
            BorderThickness="2">

        <Grid Margin="12 0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>   <!-- mic icon -->
                <ColumnDefinition Width="*"/>       <!-- waveform + status -->
                <ColumnDefinition Width="Auto"/>   <!-- gear button -->
                <ColumnDefinition Width="Auto"/>   <!-- mute button -->
            </Grid.ColumnDefinitions>

            <!-- ── Microphone icon ── -->
            <TextBlock Grid.Column="0"
                       Text="🎤"
                       FontSize="18"
                       FontFamily="Segoe UI Emoji"
                       VerticalAlignment="Center"
                       Margin="0 0 8 0"/>

            <!-- ── Centre: waveform bars (data-bound ScaleY) + status label ── -->
            <StackPanel Grid.Column="1" VerticalAlignment="Center">

                <Grid Height="26" ClipToBounds="False">
                    <StackPanel Orientation="Horizontal"
                                VerticalAlignment="Bottom"
                                HorizontalAlignment="Center">

                        <Rectangle Width="3" Height="12"
                                   Fill="#B4E4FF" RadiusX="1.5" RadiusY="1.5"
                                   VerticalAlignment="Bottom" Margin="2 0"
                                   RenderTransformOrigin="0.5,1">
                            <Rectangle.RenderTransform>
                                <ScaleTransform ScaleY="{Binding Bar1Scale}"/>
                            </Rectangle.RenderTransform>
                        </Rectangle>

                        <Rectangle Width="3" Height="18"
                                   Fill="#B4E4FF" RadiusX="1.5" RadiusY="1.5"
                                   VerticalAlignment="Bottom" Margin="2 0"
                                   RenderTransformOrigin="0.5,1">
                            <Rectangle.RenderTransform>
                                <ScaleTransform ScaleY="{Binding Bar2Scale}"/>
                            </Rectangle.RenderTransform>
                        </Rectangle>

                        <Rectangle Width="3" Height="24"
                                   Fill="#B4E4FF" RadiusX="1.5" RadiusY="1.5"
                                   VerticalAlignment="Bottom" Margin="2 0"
                                   RenderTransformOrigin="0.5,1">
                            <Rectangle.RenderTransform>
                                <ScaleTransform ScaleY="{Binding Bar3Scale}"/>
                            </Rectangle.RenderTransform>
                        </Rectangle>

                        <Rectangle Width="3" Height="18"
                                   Fill="#B4E4FF" RadiusX="1.5" RadiusY="1.5"
                                   VerticalAlignment="Bottom" Margin="2 0"
                                   RenderTransformOrigin="0.5,1">
                            <Rectangle.RenderTransform>
                                <ScaleTransform ScaleY="{Binding Bar4Scale}"/>
                            </Rectangle.RenderTransform>
                        </Rectangle>

                        <Rectangle Width="3" Height="12"
                                   Fill="#B4E4FF" RadiusX="1.5" RadiusY="1.5"
                                   VerticalAlignment="Bottom" Margin="2 0"
                                   RenderTransformOrigin="0.5,1">
                            <Rectangle.RenderTransform>
                                <ScaleTransform ScaleY="{Binding Bar5Scale}"/>
                            </Rectangle.RenderTransform>
                        </Rectangle>

                    </StackPanel>
                </Grid>

                <TextBlock Text="{Binding StatusText}"
                           Foreground="{DynamicResource OnSurfaceVariantBrush}"
                           FontSize="10"
                           FontFamily="Segoe UI"
                           HorizontalAlignment="Center"
                           Margin="0 2 0 0"/>
            </StackPanel>

            <!-- ── Gear button: opens full settings popup ── -->
            <Button x:Name="GearButton"
                    Grid.Column="2"
                    Width="26" Height="26"
                    VerticalAlignment="Center"
                    Cursor="Hand"
                    Click="GearButton_Click"
                    ToolTip="Settings"
                    Margin="0 0 4 0">
                <Button.Template>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd" CornerRadius="13" Background="#33FFFFFF">
                            <TextBlock Text="⚙"
                                       FontSize="11"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center"
                                       Foreground="White"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#55FFFFFF"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Button.Template>
            </Button>

            <!-- ── Full settings popup ── -->
            <Popup x:Name="SettingsPopup"
                   Grid.Column="2"
                   PlacementTarget="{Binding ElementName=GearButton}"
                   Placement="Bottom"
                   VerticalOffset="6"
                   StaysOpen="False"
                   AllowsTransparency="True">
                <Border Background="#F01A1A2E"
                        CornerRadius="12"
                        BorderBrush="#55FFFFFF"
                        BorderThickness="1"
                        Width="268">
                    <ScrollViewer MaxHeight="420"
                                  VerticalScrollBarVisibility="Auto"
                                  Padding="0">
                        <StackPanel Margin="14 12">

                            <!-- MICROPHONE -->
                            <TextBlock Text="MICROPHONE"
                                       Foreground="#77FFFFFF" FontSize="9"
                                       FontWeight="SemiBold" Margin="0 0 0 5"/>
                            <ComboBox x:Name="SettingsMicCombo"
                                      HorizontalAlignment="Stretch"
                                      Margin="0 0 0 12"
                                      SelectionChanged="SettingsMicCombo_SelectionChanged"/>

                            <!-- BEHAVIOUR -->
                            <TextBlock Text="BEHAVIOUR"
                                       Foreground="#77FFFFFF" FontSize="9"
                                       FontWeight="SemiBold" Margin="0 0 0 5"/>
                            <CheckBox x:Name="AlwaysOnTopCheck"
                                      Content="Always on top"
                                      Foreground="White" Margin="0 0 0 5"
                                      Checked="AlwaysOnTopCheck_Changed"
                                      Unchecked="AlwaysOnTopCheck_Changed"/>
                            <CheckBox x:Name="StartWithWindowsCheck"
                                      Content="Start with Windows"
                                      Foreground="White" Margin="0 0 0 5"
                                      Checked="StartWithWindowsCheck_Changed"
                                      Unchecked="StartWithWindowsCheck_Changed"/>
                            <CheckBox x:Name="SaveHistoryCheck"
                                      Content="Save transcription history"
                                      Foreground="White" Margin="0 0 0 12"
                                      Checked="SaveHistoryCheck_Changed"
                                      Unchecked="SaveHistoryCheck_Changed"/>

                            <!-- APPEARANCE -->
                            <TextBlock Text="APPEARANCE"
                                       Foreground="#77FFFFFF" FontSize="9"
                                       FontWeight="SemiBold" Margin="0 0 0 5"/>
                            <StackPanel Orientation="Horizontal" Margin="0 0 0 12">
                                <RadioButton x:Name="ThemeSystemRadio"
                                             Content="System"
                                             Foreground="White"
                                             GroupName="OverlayTheme"
                                             Margin="0 0 10 0"
                                             Checked="ThemeRadio_Checked"/>
                                <RadioButton x:Name="ThemeLightRadio"
                                             Content="Light"
                                             Foreground="White"
                                             GroupName="OverlayTheme"
                                             Margin="0 0 10 0"
                                             Checked="ThemeRadio_Checked"/>
                                <RadioButton x:Name="ThemeDarkRadio"
                                             Content="Dark"
                                             Foreground="White"
                                             GroupName="OverlayTheme"
                                             Checked="ThemeRadio_Checked"/>
                            </StackPanel>

                            <!-- DATA -->
                            <TextBlock Text="DATA"
                                       Foreground="#77FFFFFF" FontSize="9"
                                       FontWeight="SemiBold" Margin="0 0 0 5"/>
                            <StackPanel Orientation="Horizontal" Margin="0 0 0 12">
                                <Button Content="Clear History"
                                        Click="ClearHistoryBtn_Click"
                                        Padding="8 4" FontSize="11"
                                        Margin="0 0 6 0"/>
                                <Button Content="View History"
                                        Click="ViewHistoryBtn_Click"
                                        Padding="8 4" FontSize="11"/>
                            </StackPanel>

                            <!-- APP -->
                            <TextBlock Text="APP"
                                       Foreground="#77FFFFFF" FontSize="9"
                                       FontWeight="SemiBold" Margin="0 0 0 5"/>
                            <TextBlock x:Name="PopupVersionLabel"
                                       Foreground="#77FFFFFF" FontSize="10"
                                       Margin="0 0 0 6"/>
                            <StackPanel Orientation="Horizontal">
                                <Button Content="Help &amp; Support"
                                        Click="HelpBtn_Click"
                                        Padding="8 4" FontSize="11"
                                        Margin="0 0 6 0"/>
                                <Button Content="Exit"
                                        Click="ExitBtn_Click"
                                        Padding="8 4" FontSize="11"/>
                            </StackPanel>

                        </StackPanel>
                    </ScrollViewer>
                </Border>
            </Popup>

            <!-- ── Mute button ── -->
            <Button x:Name="MuteButton"
                    Grid.Column="3"
                    Width="28" Height="28"
                    VerticalAlignment="Center"
                    Cursor="Hand"
                    Click="MuteButton_Click"
                    ToolTip="Stop listening">
                <Button.Template>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd" CornerRadius="14" Background="#33FFFFFF">
                            <TextBlock Text="🔇"
                                       FontSize="12"
                                       FontFamily="Segoe UI Emoji"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#55FFFFFF"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#77FFFFFF"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Button.Template>
            </Button>

        </Grid>
    </Border>

</Window>
