<wpfui:FluentWindow
    x:Class="InstaType.Views.LoginWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:wpfui="http://schemas.lepo.co/wpfui/2022/xaml"
    Title="InstaType Account"
    Width="400" Height="520"
    WindowStartupLocation="CenterScreen"
    Background="{x:Null}"
    ExtendsContentIntoTitleBar="True"
    ResizeMode="NoResize">

    <Grid Margin="32 52 32 32">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>  <!-- Logo / title -->
            <RowDefinition Height="24"/>
            <RowDefinition Height="Auto"/>  <!-- Email -->
            <RowDefinition Height="12"/>
            <RowDefinition Height="Auto"/>  <!-- Password -->
            <RowDefinition Height="20"/>
            <RowDefinition Height="Auto"/>  <!-- Sign-in button -->
            <RowDefinition Height="12"/>
            <RowDefinition Height="Auto"/>  <!-- Google button -->
            <RowDefinition Height="16"/>
            <RowDefinition Height="Auto"/>  <!-- Status text -->
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>  <!-- Toggle mode link -->
        </Grid.RowDefinitions>

        <!-- Title -->
        <StackPanel Grid.Row="0" HorizontalAlignment="Center">
            <TextBlock Text="InstaType"
                       FontSize="26" FontWeight="Bold"
                       HorizontalAlignment="Center"/>
            <TextBlock x:Name="SubtitleText"
                       Text="Sign in to your account"
                       FontSize="13" Foreground="Gray"
                       HorizontalAlignment="Center" Margin="0 4 0 0"/>
        </StackPanel>

        <!-- Email -->
        <wpfui:TextBox Grid.Row="2"
                       x:Name="EmailBox"
                       PlaceholderText="Email address"
                       Text="{Binding Email, UpdateSourceTrigger=PropertyChanged}"
                       KeyDown="Input_KeyDown"/>

        <!-- Password -->
        <PasswordBox Grid.Row="4"
                     x:Name="PasswordBox"
                     KeyDown="Input_KeyDown"
                     Style="{StaticResource {x:Type PasswordBox}}"/>

        <!-- Sign In button -->
        <wpfui:Button Grid.Row="6"
                      x:Name="SignInBtn"
                      Content="Sign In"
                      Appearance="Primary"
                      Width="336"
                      HorizontalAlignment="Center"
                      Click="SignInBtn_Click"/>

        <!-- Google OAuth button -->
        <Button Grid.Row="8"
                x:Name="GoogleBtn"
                Width="336"
                HorizontalAlignment="Center"
                Click="GoogleBtn_Click"
                Padding="0 8">
            <StackPanel Orientation="Horizontal">
                <TextBlock Text="G" FontWeight="Bold" FontSize="14"
                           Foreground="#4285F4" Margin="0 0 8 0"
                           VerticalAlignment="Center"/>
                <TextBlock Text="Continue with Google" VerticalAlignment="Center"/>
            </StackPanel>
        </Button>

        <!-- Status / error text -->
        <TextBlock Grid.Row="10"
                   x:Name="StatusBlock"
                   Text="{Binding StatusText}"
                   Foreground="#E53935"
                   FontSize="12"
                   TextWrapping="Wrap"
                   HorizontalAlignment="Center"
                   TextAlignment="Center"/>

        <!-- Loading spinner (visible only during IsLoading) -->
        <wpfui:ProgressRing Grid.Row="10"
                            x:Name="LoadingRing"
                            Width="24" Height="24"
                            Visibility="Collapsed"
                            HorizontalAlignment="Center"/>

        <!-- Toggle create / sign-in mode -->
        <Button Grid.Row="12"
                x:Name="ToggleModeBtn"
                Content="{Binding ToggleModeLabel}"
                Background="Transparent"
                BorderThickness="0"
                Foreground="{DynamicResource AccentTextFillColorPrimaryBrush}"
                HorizontalAlignment="Center"
                Click="ToggleModeBtn_Click"/>
    </Grid>

</wpfui:FluentWindow>
